# Copy this to .env and fill in real values — never commit .env

# Session signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-32-char-random-string

# Google Workspace SMTP Relay
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USER=jp@topsisconsulting.com
SMTP_PASSWORD=replace-with-google-app-password
EMAIL_FROM=info@topsisconsulting.com
EMAIL_FROM_NAME=Topsis Consulting

# Jira Cloud
JIRA_URL=https://topsis.atlassian.net
JIRA_USER_EMAIL=jp@topsisconsulting.com
JIRA_API_TOKEN=replace-with-jira-api-token

# Redis — for local dev, run: docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# Set to "true" in local dev to skip actual email sending (prints OTP to console instead)
DEV_MODE=true
